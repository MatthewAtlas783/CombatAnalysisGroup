{
  "name": "tumba-analysis",
  "productName": "TumbaAnalysis",
  "version": "1.0.1",
  "description": "Real-time group combat parses for LOTRO",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-vite build && electron-builder --win --x64",
    "package:dir": "electron-vite build && electron-builder --win --x64 --dir",
    "release": "electron-vite build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
