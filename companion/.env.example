# Relay endpoint. ws:// for local dev, wss:// for production.
CAG_RELAY_URL=ws://localhost:8787

# Room everyone in your raid joins. Anything 4-32 chars; share it with raid members.
CAG_ROOM=my-raid

# Your character name. If unset, the companion waits for the plugin to publish it
# via CALocalStats.plugindata, or you can set it manually here.
# CAG_PLAYER=Hechicero

# Override the LOTRO PluginData directory if auto-detect fails.
# CAG_PLUGINDATA_DIR=C:\Users\you\OneDrive\Documents\The Lord of the Rings Online\PluginData

# Limit which LOTRO account folder we read/write. By default we use the most
# recently modified one. Set this if you have multiple accounts on the same PC.
# CAG_ACCOUNT=1234567890
